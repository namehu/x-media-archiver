{
  "name": "x-media-archiver-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "check": "npm run typecheck && npm run build",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "typecheck": "wxt prepare && tsc --noEmit"
  },
  "dependencies": {
    "@wxt-dev/module-react": "^1.1.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "wxt": "^0.20.26"
  },
  "devDependencies": {
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "typescript": "^5.9.2"
  }
}
