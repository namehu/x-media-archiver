# Production environment for docker-compose.prod.yml.
# Copy to .env.production and edit. This file is git-ignored (.env.* except .env.example).

# --- Bundled Postgres (default) ---------------------------------------------
# These are consumed by the `postgres` service. Use a strong password.
POSTGRES_DB=xarchiver
POSTGRES_USER=xarchiver
POSTGRES_PASSWORD=change_me_strong_password

# DATABASE_URL is consumed by the app. For the bundled Postgres above, the host
# is the compose service name `postgres`. Keep credentials in sync with the
# POSTGRES_* values. URL-encode any special characters in the password.
DATABASE_URL=postgresql://xarchiver:change_me_strong_password@postgres:5432/xarchiver

# --- External Postgres (e.g. Supabase) — alternative ------------------------
# To use an external database instead, set DATABASE_URL below, then remove the
# `postgres` service and `depends_on` block in docker-compose.prod.yml.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# --- Application paths (container-internal; leave as-is) ---------------------
ARCHIVE_DIR=/app/archive
COOKIE_FILE=/app/secrets/cookies.txt

# --- Download / retry tuning -------------------------------------------------
DEFAULT_DOWNLOAD_ENGINE=gallery-dl
RETRY_LIMIT=3
RETRY_BACKOFF_MINUTES=15
STUCK_TIMEOUT_MINUTES=120
QUEUE_BATCH_SIZE=20
DOWNLOADER_SLEEP_MIN_SECONDS=2
DOWNLOADER_SLEEP_MAX_SECONDS=6

# --- Source scanning (independent of downloads) ------------------------------
SOURCE_SCAN_BATCH_SIZE=20
SOURCE_SCAN_SLEEP_MIN_SECONDS=20
SOURCE_SCAN_SLEEP_MAX_SECONDS=45

# --- API server --------------------------------------------------------------
# API_HOST is forced to 0.0.0.0 inside the image; the port maps to the host
# loopback in compose. Change API_PORT to relocate the published port.
API_PORT=8000
