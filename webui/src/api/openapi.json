  "components": {
    "schemas": {
      "ArchiveRecord": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          },
          "author_username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Author Username"
          },
          "author_display_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Author Display Name"
          },
          "text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Text"
          },
          "published_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Published At"
          },
          "datetime": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Datetime"
          },
          "collected_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Collected At"
          },
          "source_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Url"
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "ArchiveRecord"
      },
      "ArchiveSubmitRequest": {
        "properties": {
          "trigger_type": {
            "type": "string",
            "title": "Trigger Type",
            "default": "webui"
          },
          "records": {
            "items": {
              "$ref": "#/components/schemas/ArchiveRecord"
            },
            "type": "array",
            "title": "Records"
          }
        },
        "type": "object",
        "required": [
          "records"
        ],
        "title": "ArchiveSubmitRequest"
      },
      "BackfillRequest": {
        "properties": {
          "confirm_full_scan": {
            "type": "boolean",
            "title": "Confirm Full Scan",
            "default": false
          },
          "normalize_files": {
            "type": "boolean",
            "title": "Normalize Files",
            "default": true
          }
        },
        "type": "object",
        "title": "BackfillRequest"
      },
      "ExportRequest": {
        "properties": {
          "kind": {
            "type": "string",
            "pattern": "^(media|failures|duplicates)$",
            "title": "Kind",
            "default": "media"
          },
          "status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Status",
            "default": "verified"
          }
        },
        "type": "object",
        "title": "ExportRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "RecoverInterruptedRequest": {
        "properties": {
          "timeout_minutes": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 1.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Timeout Minutes"
          }
        },
        "type": "object",
        "title": "RecoverInterruptedRequest"
