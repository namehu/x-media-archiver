            },
            "type": "array",
            "title": "Records"
          }
        },
        "type": "object",
        "required": [
          "records"
        ],
        "title": "SourceRecordsRequest"
      },
      "SourceScanRequest": {
        "properties": {
          "limit": {
            "type": "integer",
            "maximum": 200.0,
            "minimum": 1.0,
            "title": "Limit",
            "default": 20
          },
          "restart": {
            "type": "boolean",
            "title": "Restart",
            "default": false
          }
        },
        "type": "object",
        "title": "SourceScanRequest"
      },
      "SourceStatusRequest": {
        "properties": {
          "status": {
            "type": "string",
            "pattern": "^(active|paused|completed|failed)$",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "SourceStatusRequest"
      },
      "SourceSubmitDiscoveredRequest": {
        "properties": {
          "limit": {
            "anyOf": [
              {
